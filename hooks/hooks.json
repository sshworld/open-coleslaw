{
  "hooks": {
    "Setup": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/setup.sh\"",
            "timeout": 300
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && [ -f dist/index.js ] || \"${CLAUDE_PLUGIN_ROOT}/scripts/setup.sh\" 2>/dev/null; \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start\"",
            "timeout": 120,
            "async": false
          }
        ]
      }
    ]
  }
}
