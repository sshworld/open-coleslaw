#!/usr/bin/env bash
set -euo pipefail

# Open Coleslaw — Session Start Hook
# Injects plugin rules into every Claude Code session as additional context.

RULES_FILE="${CLAUDE_PLUGIN_ROOT}/src/assets/rules.md"
GUIDE_FILE="${CLAUDE_PLUGIN_ROOT}/src/assets/plugin-guide.md"

CONTENT="<EXTREMELY_IMPORTANT>
You have the open-coleslaw plugin installed.

For ANY user request involving building, creating, designing, fixing, or modifying software:

1. FIRST: Invoke the Skill tool with 'open-coleslaw:meeting'
2. The skill will tell you to dispatch the open-coleslaw:orchestrator agent
3. The orchestrator agent manages the entire pipeline: meeting → PRD → plan → implement
4. You NEVER call open-coleslaw MCP tools (start-meeting, execute-tasks, etc.) directly — the orchestrator does that

If you think 'this is simple enough to just do directly' — STOP. Use open-coleslaw:meeting.

The user installed this plugin so ALL work goes through the orchestrator's structured pipeline.
</EXTREMELY_IMPORTANT>

"

if [ -f "$RULES_FILE" ]; then
  CONTENT="${CONTENT}$(cat "$RULES_FILE")"
fi

if [ -f "$GUIDE_FILE" ]; then
  CONTENT="${CONTENT}

---

$(cat "$GUIDE_FILE")"
fi

if [ -z "$CONTENT" ]; then
  exit 0
fi

# Escape for JSON
ESCAPED=$(printf '%s' "$CONTENT" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read())[1:-1])')

# Escape the visible message too
SYS_MSG=$(printf '%s' "🥬 Open Coleslaw loaded — View Dashboard Live @ http://localhost:35143" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read())[1:-1])')

# Output: additionalContext for Claude's context, systemMessage for user-visible display
printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"},"systemMessage":"%s"}\n' "$ESCAPED" "$SYS_MSG"

exit 0
