#!/usr/bin/env bash
set -euo pipefail

# Open Coleslaw — Session Start Hook
# Injects the using-open-coleslaw skill content directly into every session.
# Same pattern as superpowers: load the full skill at session start.

SKILL_FILE="${CLAUDE_PLUGIN_ROOT}/skills/using-open-coleslaw/SKILL.md"
RULES_FILE="${CLAUDE_PLUGIN_ROOT}/src/assets/rules.md"

CONTENT="<EXTREMELY_IMPORTANT>
You have open-coleslaw installed.

**Below is the full content of your 'open-coleslaw:using-open-coleslaw' skill — your guide to using open-coleslaw. For other skills, use the Skill tool:**

---
"

# Load the using-open-coleslaw skill content directly
if [ -f "$SKILL_FILE" ]; then
  CONTENT="${CONTENT}$(cat "$SKILL_FILE")"
fi

# Append rules
if [ -f "$RULES_FILE" ]; then
  CONTENT="${CONTENT}

---

$(cat "$RULES_FILE")"
fi

CONTENT="${CONTENT}
</EXTREMELY_IMPORTANT>"

# Escape for JSON
ESCAPED=$(printf '%s' "$CONTENT" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read())[1:-1])')

# Visible greeting
SYS_MSG=$(printf '%s' "🥬 Open Coleslaw loaded — View Dashboard Live @ http://localhost:35143" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read())[1:-1])')

printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"},"systemMessage":"%s"}\n' "$ESCAPED" "$SYS_MSG"

exit 0
