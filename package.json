{
  "name": "open-coleslaw",
  "version": "0.1.5",
  "description": "Multi-agent orchestrator MCP plugin for Claude Code with hierarchical agent system",
  "type": "module",
  "bin": {
    "open-coleslaw": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "tsup"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude-code",
    "mcp",
    "agent",
    "orchestrator",
    "multi-agent"
  ],
  "author": "sshworld",
  "repository": {
    "type": "git",
    "url": "https://github.com/sshworld/open-coleslaw.git"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
