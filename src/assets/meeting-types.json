{
  "meetingTypes": {
    "kickoff": {
      "description": "Decompose a user request into ordered MVPs",
      "defaultDepartments": ["planning", "product"],
      "defaultAgenda": [
        "Restate user request",
        "Decompose into ordered MVPs",
        "Confirm first MVP scope"
      ],
      "maxRoundsPerItem": 10
    },
    "design": {
      "description": "Design a single MVP: decide approach, scope, acceptance criteria",
      "defaultDepartments": ["planning", "architecture", "engineering", "verification"],
      "defaultAgenda": [
        "Review MVP goal and scope",
        "Evaluate design options",
        "Decide approach and acceptance criteria"
      ],
      "maxRoundsPerItem": 10
    },
    "verify-retry": {
      "description": "Respond to verification failure and plan a fix",
      "defaultDepartments": ["planning", "engineering", "verification"],
      "defaultAgenda": [
        "Review failure details",
        "Diagnose root cause",
        "Agree on fix and updated acceptance criteria"
      ],
      "maxRoundsPerItem": 10
    },
    "design-review": {
      "description": "Review an existing system or feature design",
      "defaultDepartments": ["planning", "architecture", "engineering"],
      "defaultAgenda": [
        "Review requirements",
        "Evaluate design options",
        "Decide on approach"
      ],
      "maxRoundsPerItem": 10
    },
    "code-review": {
      "description": "Review code changes for quality, correctness, and conventions",
      "defaultDepartments": ["planning", "engineering", "verification"],
      "defaultAgenda": [
        "Review changed files and diffs",
        "Check correctness and edge cases",
        "Assess test coverage and style compliance"
      ],
      "maxRoundsPerItem": 10
    },
    "sprint-planning": {
      "description": "Plan work items for the upcoming sprint",
      "defaultDepartments": ["planning", "product", "engineering", "architecture"],
      "defaultAgenda": [
        "Review backlog and priorities",
        "Estimate effort for candidate items",
        "Commit to sprint scope"
      ],
      "maxRoundsPerItem": 10
    },
    "bug-triage": {
      "description": "Triage and prioritize reported bugs",
      "defaultDepartments": ["planning", "engineering", "verification", "product"],
      "defaultAgenda": [
        "Review reported bugs",
        "Assess severity and impact",
        "Assign owners and priorities"
      ],
      "maxRoundsPerItem": 10
    }
  }
}
